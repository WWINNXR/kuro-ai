# ── LINE ──────────────────────────────────────────────────────────────────────
# From LINE Developers Console → Your channel → Basic settings
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# From LINE Developers Console → Your channel → Messaging API → Channel access token
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# ── OpenAI ────────────────────────────────────────────────────────────────────
# From platform.openai.com → API keys
OPENAI_API_KEY=sk-...

# ── Supabase ──────────────────────────────────────────────────────────────────
# From Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # NOT the anon key

# ── Cron protection ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Add to Vercel dashboard as environment variable
CRON_SECRET=your_random_secret_here
